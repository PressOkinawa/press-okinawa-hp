---
import Header from "../../components/header.astro";
import Footer from "../../components/footer.astro";
import "../../styles/style.css";

const TITLE = "プレス沖縄｜コマーシャル";
const DESC = "プレス沖縄のコマーシャル制作実績。店内CM・PR動画など、最新の実績をご覧ください。";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>{TITLE}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={DESC} />
  </head>

  <body>
    <Header />
    <main>
      <section class="cm-works">
        <h2 class="cm-works-title">最新の実績です</h2>

        <a href="https://www.instagram.com/reel/DXIB8T3jbCQ/" target="_blank" rel="noopener noreferrer" class="work-card">
          <div class="work-card-body work-card-body--text-only">
            <p class="work-card-caption">
              当社では、砂辺インテリア様よりご依頼をいただき、<br />
              A1サイズ（841 × 594 mm）のポスターを制作・納品いたしました。<br />
              デザインから印刷まで一貫して対応し、制作費用は１点5,000円。<br />
              清潔感を重視し、信頼感のある仕上がりを意識したデザインとなっております。<br />
              当社専属モデルを起用しているため、品質面でも安心してご依頼いただけます。
            </p>
            <span class="work-card-link">▶ Instagramで見る</span>
          </div>
        </a>

      </section>
    </main>

    <Footer />

    <style>
      .cm-works {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.2rem;
        padding: 2rem 1rem;
        max-width: 800px;
        margin: 0 auto;
      }
      .cm-works-title {
        font-size: 1.6rem;
        margin-bottom: 0.4rem;
        color: #333;
        font-weight: 700;
      }
      .work-card {
        display: block;
        width: 100%;
        max-width: 500px;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.10);
        overflow: hidden;
        text-decoration: none;
        color: #333;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
      }
      .work-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 28px rgba(0,0,0,0.16);
      }
      .work-card-body {
        padding: 1rem 1.2rem 1.2rem;
        text-align: left;
      }
      .work-card-caption {
        font-size: 0.92rem;
        line-height: 1.7;
        margin: 0 0 0.8rem;
        color: #333;
      }
      .work-card-link {
        display: inline-block;
        padding: 0.45rem 1.2rem;
        background: linear-gradient(135deg, #E1306C, #F77737);
        color: #fff;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 700;
      }
      .work-card-body--text-only {
        padding: 1.5rem 1.4rem;
        background: linear-gradient(135deg, #f8f8f8, #fff);
        border-left: 4px solid #E1306C;
      }
      @media screen and (max-width: 768px) {
        .cm-works {
          padding: 1rem 0.5rem;
          gap: 0.8rem;
        }
        .cm-works-title {
          font-size: 1.2rem;
        }
        .work-card {
          max-width: 100%;
        }
      }
    </style>
  </body>
</html>
