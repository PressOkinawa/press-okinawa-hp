---
import Header from "../../components/header.astro";
import Footer from "../../components/footer.astro";
import "../../styles/style.css";

const TITLE = "プレス沖縄｜ホームページ制作";
const DESC = "プレス沖縄のホームページ制作実績。最新の制作事例をご覧ください。";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>{TITLE}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={DESC} />
  </head>

  <body>
    <Header />
    <main>
      <section class="hp-works">
        <h2 class="hp-works-title">最新の実績です</h2>
        <a href="https://www.instagram.com/reel/DXI5DDADdY_/" target="_blank" rel="noopener noreferrer" class="work-card">
          <div class="work-card-body work-card-body--text-only">
            <p class="work-card-caption">
              プレス沖縄です。<br />
              砂辺クリニック様のホームページ制作を担当<br />
              運用1年でLINE友だち6,300人達成！<br />
              予約の約7割がLINE経由に<br />
              さらに、モデル事務所も運営しているため<br />
              オリジナル素材も提供可能。著作権も安心です。<br />
              初期費用１０万円・毎月の更新料５千円で契約しました。
            </p>
            <span class="work-card-link">▶ Instagramで見る</span>
          </div>
        </a>

        <div class="site-showcase">
          <h3 class="site-showcase-label">制作実績</h3>
          <a href="https://www.sunabeclinic.com/" target="_blank" rel="noopener noreferrer" class="site-showcase-card">
            <div class="site-showcase-badge">WEBSITE</div>
            <p class="site-showcase-name">砂辺クリニック 様</p>
            <p class="site-showcase-url">www.sunabeclinic.com</p>
            <span class="site-showcase-btn">サイトを見る →</span>
          </a>
        </div>
      </section>
    </main>

    <Footer />

    <style>
      .hp-works {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.2rem;
        padding: 2rem 1rem;
        max-width: 800px;
        margin: 0 auto;
      }
      .hp-works-title {
        font-size: 1.6rem;
        margin-bottom: 0.4rem;
        color: #333;
        font-weight: 700;
      }
      .work-card {
        display: block;
        width: 100%;
        max-width: 500px;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.10);
        overflow: hidden;
        text-decoration: none;
        color: #333;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
      }
      .work-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 28px rgba(0,0,0,0.16);
      }
      .work-card-body {
        padding: 1rem 1.2rem 1.2rem;
        text-align: left;
      }
      .work-card-caption {
        font-size: 0.92rem;
        line-height: 1.7;
        margin: 0 0 0.8rem;
        color: #333;
      }
      .work-card-link {
        display: inline-block;
        padding: 0.45rem 1.2rem;
        background: linear-gradient(135deg, #E1306C, #F77737);
        color: #fff;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 700;
      }
      .work-card-body--text-only {
        padding: 1.5rem 1.4rem;
        background: linear-gradient(135deg, #f8f8f8, #fff);
        border-left: 4px solid #E1306C;
      }
      @media screen and (max-width: 768px) {
        .hp-works {
          padding: 1rem 0.5rem;
          gap: 0.8rem;
        }
        .hp-works-title {
          font-size: 1.2rem;
        }
        .work-card {
          max-width: 100%;
        }
      }

      .site-showcase {
        max-width: 540px;
        margin: 2rem auto 0;
      }
      .site-showcase-label {
        font-size: 1.1rem;
        color: #0d47a1;
        font-weight: 700;
        margin-bottom: 0.8rem;
        letter-spacing: 0.05em;
      }
      .site-showcase-card {
        display: block;
        background: linear-gradient(135deg, #0d47a1, #1976d2);
        color: #fff;
        border-radius: 14px;
        padding: 2rem 1.5rem;
        text-decoration: none;
        box-shadow: 0 10px 30px rgba(13, 71, 161, 0.3);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }
      .site-showcase-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 40px rgba(13, 71, 161, 0.4);
      }
      .site-showcase-badge {
        display: inline-block;
        background: rgba(255,255,255,0.2);
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        margin-bottom: 0.8rem;
      }
      .site-showcase-name {
        font-size: 1.4rem;
        font-weight: 700;
        margin: 0 0 0.4rem;
      }
      .site-showcase-url {
        font-size: 0.9rem;
        opacity: 0.8;
        margin: 0 0 1rem;
      }
      .site-showcase-btn {
        display: inline-block;
        background: #fff;
        color: #0d47a1;
        padding: 0.5rem 1.5rem;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.95rem;
      }
      @media screen and (max-width: 768px) {
        .site-showcase {
          max-width: 100%;
          margin: 1.5rem auto 0;
        }
        .site-showcase-card {
          padding: 1.5rem 1rem;
        }
        .site-showcase-name {
          font-size: 1.2rem;
        }
      }
    </style>
  </body>
</html>
