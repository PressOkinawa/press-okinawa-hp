---
import Header from "../../components/header.astro";
import Footer from "../../components/footer.astro";
import "../../styles/style.css";

const TITLE = "プレス沖縄｜ホームページ制作";
const DESC = "プレス沖縄のホームページ制作実績。最新の制作事例をご覧ください。";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>{TITLE}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={DESC} />
  </head>

  <body>
    <Header />
    <main>
      <section class="hp-works">
        <h2 class="hp-works-title">最新の実績です</h2>
        <div class="instagram-embed-wrapper">
          <blockquote
            class="instagram-media"
            data-instgrm-captioned
            data-instgrm-permalink="https://www.instagram.com/reel/DXI5DDADdY_/"
            data-instgrm-version="14"
            style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin:1px auto; max-width:540px; min-width:326px; padding:0; width:calc(100% - 2px);">
          </blockquote>
        </div>

        <div class="site-showcase">
          <h3 class="site-showcase-label">制作実績</h3>
          <a href="https://www.sunabeclinic.com/" target="_blank" rel="noopener noreferrer" class="site-showcase-card">
            <div class="site-showcase-badge">WEBSITE</div>
            <p class="site-showcase-name">砂辺クリニック 様</p>
            <p class="site-showcase-url">www.sunabeclinic.com</p>
            <span class="site-showcase-btn">サイトを見る →</span>
          </a>
        </div>
      </section>
    </main>

    <Footer />

    <script async src="https://www.instagram.com/embed.js"></script>

    <style>
      .hp-works {
        text-align: center;
        padding: 2rem 1rem;
        max-width: 800px;
        margin: 0 auto;
      }
      .hp-works-title {
        font-size: 1.6rem;
        margin-bottom: 1.2rem;
        color: #333;
        font-weight: 700;
      }
      .instagram-embed-wrapper {
        max-width: 540px;
        margin: 0 auto 1.5rem;
      }
      @media screen and (max-width: 768px) {
        .hp-works {
          padding: 1rem 0.5rem;
        }
        .hp-works-title {
          font-size: 1.2rem;
        }
        .instagram-embed-wrapper {
          max-width: 100%;
        }
      }

      .site-showcase {
        max-width: 540px;
        margin: 2rem auto 0;
      }
      .site-showcase-label {
        font-size: 1.1rem;
        color: #0d47a1;
        font-weight: 700;
        margin-bottom: 0.8rem;
        letter-spacing: 0.05em;
      }
      .site-showcase-card {
        display: block;
        background: linear-gradient(135deg, #0d47a1, #1976d2);
        color: #fff;
        border-radius: 14px;
        padding: 2rem 1.5rem;
        text-decoration: none;
        box-shadow: 0 10px 30px rgba(13, 71, 161, 0.3);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }
      .site-showcase-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 40px rgba(13, 71, 161, 0.4);
      }
      .site-showcase-badge {
        display: inline-block;
        background: rgba(255,255,255,0.2);
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        margin-bottom: 0.8rem;
      }
      .site-showcase-name {
        font-size: 1.4rem;
        font-weight: 700;
        margin: 0 0 0.4rem;
      }
      .site-showcase-url {
        font-size: 0.9rem;
        opacity: 0.8;
        margin: 0 0 1rem;
      }
      .site-showcase-btn {
        display: inline-block;
        background: #fff;
        color: #0d47a1;
        padding: 0.5rem 1.5rem;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.95rem;
      }
      @media screen and (max-width: 768px) {
        .site-showcase {
          max-width: 100%;
          margin: 1.5rem auto 0;
        }
        .site-showcase-card {
          padding: 1.5rem 1rem;
        }
        .site-showcase-name {
          font-size: 1.2rem;
        }
      }
    </style>
  </body>
</html>
