---
import Header from "../../components/header.astro";
import Footer from "../../components/footer.astro";
import "../../styles/style.css";

const TITLE = "プレス沖縄｜ホームページ制作";
const DESC = "プレス沖縄のホームページ制作実績。最新の制作事例をご覧ください。";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>{TITLE}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={DESC} />
  </head>

  <body>
    <Header />
    <main>
      <section class="hp-works">
        <h2 class="hp-works-title">最新の実績です</h2>
        <div class="instagram-embed-wrapper">
          <blockquote
            class="instagram-media"
            data-instgrm-captioned
            data-instgrm-permalink="https://www.instagram.com/reel/DXI5DDADdY_/"
            data-instgrm-version="14"
            style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin:1px auto; max-width:540px; min-width:326px; padding:0; width:calc(100% - 2px);">
          </blockquote>
        </div>
      </section>
    </main>

    <Footer />

    <script async src="https://www.instagram.com/embed.js"></script>

    <style>
      .hp-works {
        text-align: center;
        padding: 2rem 1rem;
        max-width: 800px;
        margin: 0 auto;
      }
      .hp-works-title {
        font-size: 1.6rem;
        margin-bottom: 1.2rem;
        color: #333;
        font-weight: 700;
      }
      .instagram-embed-wrapper {
        max-width: 540px;
        margin: 0 auto 1.5rem;
      }
      @media screen and (max-width: 768px) {
        .hp-works {
          padding: 1rem 0.5rem;
        }
        .hp-works-title {
          font-size: 1.2rem;
        }
        .instagram-embed-wrapper {
          max-width: 100%;
        }
      }
    </style>
  </body>
</html>
